# ============================================================================
# Environment Variables Reference
# ============================================================================
# This file documents all environment variables used in Resume-Buildr
# Copy the relevant variables to:
# - Render: artifacts/api-server/.env.render
# - Vercel: artifacts/resume-screener/.env.vercel
#
# ============================================================================

# ─── BACKEND (artifacts/api-server) ────────────────────────────────────────

# API Server Port
API_PORT=8080

# CORS allowed origins (comma-separated, no spaces)
# Example: https://resume-buildr.vercel.app
# For local dev: http://localhost:5173
ALLOWED_ORIGINS=https://resume-buildr.vercel.app

# Database URL (optional for SQLite, required for PostgreSQL)
# SQLite: sqlite:///resume_screening.db
# PostgreSQL: postgresql://user:password@host/dbname
DATABASE_URL=

# Python environment
PYTHONUNBUFFERED=1

# ─── FRONTEND (artifacts/resume-screener) ─────────────────────────────────

# Frontend Port (Vite dev server)
PORT=5173

# Base path for app deployment
# Use "/" for root-hosted
# Use "/app/" if deployed to subdirectory
BASE_PATH=/

# Backend API URL
# Dev: http://localhost:8080
# Prod: https://your-backend.onrender.com
VITE_API_URL=https://resume-buildr-api.onrender.com

# Node environment
NODE_ENV=production

# ─── OPTIONAL / FUTURE ────────────────────────────────────────────────────

# Authentication (if adding user sessions)
# JWT_SECRET=your-secret-key-here
# AUTH_PROVIDER=github

# External services
# SENTRY_DSN=https://...
# MIXPANEL_TOKEN=...

# Feature flags
# VITE_ENABLE_ADVANCED_MATCHING=true
# VITE_ENABLE_BATCH_UPLOAD=false
